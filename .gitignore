# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# raw source data (large binary files — run scripts/ to regenerate)
/data/raw/

# data files served from Cloudflare R2 — not deployed via Vercel
public/data/*.bin
public/data/*.bin.gz
public/data/*.geojson
public/data/wells-??.json
public/data/wells.json
public/data/wells-offshore.json

# playwright session state
scripts/.rrc-state.json
